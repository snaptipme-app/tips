{
  "expo": {
    "main": "expo-router/entry",
    "name": "SnapTip",
    "slug": "snaptip",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/snaptip_icon.png",
    "scheme": "snaptip",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/snaptip_icon.png",
      "backgroundColor": "#080818",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "me.snaptip.app",
      "icon": "./assets/images/snaptip_icon.png",
      "infoPlist": {
        "NSCameraUsageDescription": "SnapTip needs camera access to take profile photos.",
        "NSPhotoLibraryUsageDescription": "SnapTip needs photo library access to select profile photos."
      }
    },
    "android": {
      "navigationBar": {
        "barStyle": "light-content",
        "backgroundColor": "#00000000"
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/snaptip_icon.png",
        "backgroundColor": "#080818"
      },
      "package": "me.snaptip.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-image-picker",
      "expo-web-browser",
      "expo-av"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "969142d7-4479-465b-9ce8-46fe9e32e9c2"
      }
    }
  }
}
