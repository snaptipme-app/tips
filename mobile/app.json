{
  "expo": {
	"main": "expo-router/entry",
    "name": "SnapTip",
    "slug": "snaptip",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "snaptip",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "me.snaptip.app",
      "infoPlist": {
        "NSCameraUsageDescription": "SnapTip needs camera access to take profile photos.",
        "NSPhotoLibraryUsageDescription": "SnapTip needs photo library access to select profile photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#080818"
      },
      "package": "me.snaptip.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-image-picker"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
